# Python
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
.eggs/

# Virtual environment
.venv/
venv/
env/

# Data — actual files ignored by DVC-managed .gitignore entries inside data/
# Do NOT add data/ here: DVC pointer (.dvc) files inside data/ must be tracked by git

# MLFlow local runs (we use DagsHub, but keep local cache out of git)
mlruns/
mlartifacts/

# Model weights (large files)
*.pt
*.pth
*.onnx
*.engine

# Jupyter
.ipynb_checkpoints/

# Environment variables / secrets — .env.example is safe to commit (template only)
.env
.env.local

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp

# Hydra outputs
outputs/
multirun/

# Training run artifacts (weights, plots, logs — tracked separately in MLFlow)
runs/

# Processed data — generated by src/data/preprocess.py, contains machine-specific paths
data/processed/
